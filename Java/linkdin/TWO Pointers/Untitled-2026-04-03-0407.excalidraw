    {
      "id": "JYz3epvmG8FH4demvVypM",
      "type": "text",
      "x": 1350.5156915771722,
      "y": 358.0719273078289,
      "width": 564.8878294110928,
      "height": 315.9544128703632,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 677953453,
      "version": 1132,
      "versionNonce": 1967197091,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775172245436,
      "link": null,
      "locked": false,
      "text": "int left = 0;\nint n = heights.length;\nint right = n-1;\nint max = 0;\nwhile(left < right){\n    int left= right - left;\n    int breadth = Math.min(height[left], height[right]);\n     max = Math.max(max , length * breadth);\n     if(heights[left]<heights[right]){\n          left++;\n     }else{\n          right--;\n     }\n   }\nreturn max;",
      "fontSize": 16.850902019752706,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int left = 0;\nint n = heights.length;\nint right = n-1;\nint max = 0;\nwhile(left < right){\n    int left= right - left;\n    int breadth = Math.min(height[left], height[right]);\n     max = Math.max(max , length * breadth);\n     if(heights[left]<heights[right]){\n          left++;\n     }else{\n          right--;\n     }\n   }\nreturn max;",
      "autoResize": false,
      "lineHeight": 1.25
    },
